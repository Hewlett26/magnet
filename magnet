#!/usr/bin/env bash
set -uo pipefail

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
#  Magnet Package Management Wrapper  v0.6                #
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

#%%%%%%%%%%%%%%%%%%%%% Color %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

#%%%%%%%%%%%%%%%%%%%%% Config %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

LOGFILE="/var/log/magnet.log"
DB_DIR="/var/lib/magnet"
DB_FILE="$DB_DIR/packages.csv"
PROFILES_DIR="$DB_DIR/profiles"
PINS_FILE="$DB_DIR/pinned.txt"
LOCK_DIR="/tmp/magnet-locks"

DEBIAN_BOX="magnet-debian"
FEDORA_BOX="magnet-fedora"

# XDG paths for desktop entry cleanup (run as SUDO_USER)
XDG_APPS="${HOME}/.local/share/applications"
XDG_ICONS="${HOME}/.local/share/icons"
XDG_DATA="${HOME}/.local/share"

#%%%%%%%%%%%%%%%%%%%%% Init %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

mkdir -p "$LOCK_DIR"
mkdir -p "$DB_DIR"
mkdir -p "$PROFILES_DIR"
trap 'rm -f "$LOCK_DIR"/*.lock' EXIT INT TERM

# Create CSV with header if it doesn't exist
if [[ ! -f "$DB_FILE" ]]; then
    echo "package,source,date,user" > "$DB_FILE"
fi

#%%%%%%%%%%%%%%%%%%%%% Guards %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

if [[ -z "${SUDO_USER:-}" ]]; then
    echo -e "${RED}Error:${NC} Must be run with sudo."
    exit 1
fi

if [[ $# -eq 0 ]]; then
    echo -e "${RED}Error:${NC} No command given."
    exit 1
fi

if [[ -z "${2:-}" ]] && [[ "$1" != "update" ]] && [[ "$1" != "log" ]] && [[ "$1" != "list" ]] && [[ "$1" != "add-profile" ]] && [[ "$1" != "remove-profile" ]] && [[ "$1" != "-h" ]] && [[ "$1" != "--help" ]] && [[ "$1" != "doctor" ]]; then
    echo -e "${RED}Error:${NC} Missing argument."
    exit 1
fi

#%%%%%%%%%%%%%%%%%%%%% Logging %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

log() {
    local timestamp
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    echo -e "[MAGNET] $1"
    echo "[$timestamp] $1" >> "$LOGFILE" 2>/dev/null || true
}

log_ok()   { log "${GREEN}✔${NC} $1"; }
log_warn() { log "${YELLOW}⚠${NC}  $1"; }
log_err()  { log "${RED}✘${NC} $1"; }
log_info() { log "${CYAN}→${NC} $1"; }

#%%%%%%%%%%%%%%%%%%%%% Database %%%%%%%%%%%%%%%%%%%%%%%%%%%%

db_add() {
    local pkg="$1" source="$2"
    local date user
    date="$(date '+%Y-%m-%d %H:%M:%S')"
    user="$SUDO_USER"
    # Remove any existing entry for this package first
    db_remove "$pkg"
    echo "$pkg,$source,$date,$user" >> "$DB_FILE"
}

db_remove() {
    local pkg="$1"
    if [[ -f "$DB_FILE" ]]; then
        local tmp
        tmp="$(mktemp)"
        grep -v "^$pkg," "$DB_FILE" > "$tmp" || true
        mv "$tmp" "$DB_FILE"
    fi
}

db_get() {
    local pkg="$1"
    grep "^$pkg," "$DB_FILE" 2>/dev/null | head -1
}

db_source() {
    local pkg="$1"
    db_get "$pkg" | cut -d',' -f2
}

#%%%%%%%%%%%%%%%%%%%%% Pin Helpers %%%%%%%%%%%%%%%%%%%%%%%%%

is_pinned() {
    local pkg="$1"
    [[ -f "$PINS_FILE" ]] && grep -qx "$pkg" "$PINS_FILE"
}

pin_pkg() {
    local pkg="$1"
    if is_pinned "$pkg"; then
        log_warn "$pkg is already pinned."
        return 0
    fi
    echo "$pkg" >> "$PINS_FILE"
    log_ok "Pinned $pkg — it will be skipped during updates."
}

unpin_pkg() {
    local pkg="$1"
    if ! is_pinned "$pkg"; then
        log_warn "$pkg is not pinned."
        return 1
    fi
    local tmp
    tmp="$(mktemp)"
    grep -vx "$pkg" "$PINS_FILE" > "$tmp" || true
    mv "$tmp" "$PINS_FILE"
    log_ok "Unpinned $pkg."
}

#%%%%%%%%%%%%%%%%%%%%% Lock Helpers %%%%%%%%%%%%%%%%%%%%%%%%

declare -A LOCK_FDS

acquire_lock() {
    local name="$1"
    local lockfile="$LOCK_DIR/$name.lock"
    local fd

    mkdir -p "$LOCK_DIR" || {
        log_err "Could not create lock directory $LOCK_DIR"
        exit 1
    }

    exec {fd}>"$lockfile" || {
        log_err "Could not create lockfile $lockfile"
        exit 1
    }

    LOCK_FDS[$name]=$fd

    if ! flock -n "${LOCK_FDS[$name]}"; then
        log_err "Another magnet operation is already using $name. Aborting."
        exit 1
    fi
}

release_lock() {
    local name="$1"
    flock -u "${LOCK_FDS[$name]}"
    rm -f "$LOCK_DIR/$name.lock"
    unset "LOCK_FDS[$name]"
}

#%%%%%%%%%%%%%%%%%%%%% Helpers %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

pacman_has() {
    pacman -Si "$1" &>/dev/null
}

aur_has() {
    sudo -u "$SUDO_USER" yay -Si "$1" &>/dev/null
}

apt_has() {
    sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- apt-cache show "$1" &>/dev/null
}

dnf_has() {
    sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- dnf search "$1" &>/dev/null
}

#%%%%%%%%%%%%%%%%%%%%%% Distrobox Export %%%%%%%%%%%%%%%%%%%

# Export an app from a container to the host app menu.
# Silently skips if no .desktop file is found for the package.
distrobox_export() {
    local PKG="$1"
    local BOX="$2"

    log_info "Exporting $PKG from $BOX to host..."
    sudo -u "$SUDO_USER" distrobox enter "$BOX" -- \
        distrobox-export --app "$PKG" 2>/dev/null || {
        log_warn "Could not export $PKG from $BOX (no .desktop file found — skipping)"
    }
}

# Remove all XDG desktop entries, icons, and data dirs left behind
# by a distrobox-exported app. Searches all standard XDG locations.
purge_xdg_exports() {
    local PKG="$1"
    local USER_HOME
    USER_HOME="$(getent passwd "$SUDO_USER" | cut -d: -f6)"

    log_info "Purging XDG export artifacts for $PKG..."

    local PURGED=0

    # Desktop entries — ~/.local/share/applications and /usr/share/applications
    local desktop_dirs=(
        "$USER_HOME/.local/share/applications"
        "/usr/share/applications"
        "/usr/local/share/applications"
    )
    for dir in "${desktop_dirs[@]}"; do
        while IFS= read -r -d '' f; do
            log_info "Removing desktop entry: $f"
            rm -f "$f"
            PURGED=1
        done < <(find "$dir" -maxdepth 1 -iname "*${PKG}*" -print0 2>/dev/null)
    done

    # Icons — all standard XDG icon theme directories
    local icon_dirs=(
        "$USER_HOME/.local/share/icons"
        "/usr/share/icons"
        "/usr/share/pixmaps"
    )
    for dir in "${icon_dirs[@]}"; do
        while IFS= read -r -d '' f; do
            log_info "Removing icon: $f"
            rm -f "$f"
            PURGED=1
        done < <(find "$dir" -iname "*${PKG}*" -print0 2>/dev/null)
    done

    # App data dirs left by distrobox-export in ~/.local/share
    local data_dir="$USER_HOME/.local/share/$PKG"
    if [[ -d "$data_dir" ]]; then
        log_info "Removing data dir: $data_dir"
        rm -rf "$data_dir"
        PURGED=1
    fi

    if [[ $PURGED -eq 1 ]]; then
        # Refresh the desktop database so the app menu updates immediately
        sudo -u "$SUDO_USER" update-desktop-database \
            "$USER_HOME/.local/share/applications" 2>/dev/null || true
        log_ok "XDG artifacts purged for $PKG."
    else
        log_info "No XDG artifacts found for $PKG."
    fi
}

#%%%%%%%%%%%%%%%%%%%%%% Search %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

search_pkg() {
    local PKG="$1"
    local FOUND=0
    local DEFAULT_SOURCE=""

    log_info "Searching for ${BOLD}$PKG${NC}...\n"

    if pacman_has "$PKG"; then
        local ver
        ver="$(pacman -Si "$PKG" 2>/dev/null | awk '/^Version/ {print $3}')"
        log_ok "pacman       ${CYAN}$ver${NC}"
        [[ -z "$DEFAULT_SOURCE" ]] && DEFAULT_SOURCE="pacman"
        FOUND=1
    fi

    if command_exists yay && aur_has "$PKG"; then
        local ver
        ver="$(sudo -u "$SUDO_USER" yay -Si "$PKG" 2>/dev/null | awk '/^Version/ {print $3}' | head -1)"
        log_ok "AUR          ${CYAN}$ver${NC}"
        [[ -z "$DEFAULT_SOURCE" ]] && DEFAULT_SOURCE="aur"
        FOUND=1
    fi

    echo -e "${CYAN}→${NC} Checking Debian container..."
    if apt_has "$PKG"; then
        local ver
        ver="$(sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- \
            apt-cache show "$PKG" 2>/dev/null | awk '/^Version/ {print $2}' | head -1)"
        log_ok "Debian       ${CYAN}$ver${NC}"
        [[ -z "$DEFAULT_SOURCE" ]] && DEFAULT_SOURCE="debian"
        FOUND=1
    fi

    echo -e "${CYAN}→${NC} Checking Fedora container..."
    if dnf_has "$PKG"; then
        local ver
        ver="$(sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- \
            dnf info "$PKG" 2>/dev/null | awk '/^Version/ {print $3}' | head -1)"
        log_ok "Fedora       ${CYAN}$ver${NC}"
        [[ -z "$DEFAULT_SOURCE" ]] && DEFAULT_SOURCE="fedora"
        FOUND=1
    fi

    if [[ $FOUND -eq 0 ]]; then
        log_err "Package not found anywhere."
        exit 1
    fi

    echo ""
    log_info "Magnet would install via: ${BOLD}$DEFAULT_SOURCE${NC}"
}

#%%%%%%%%%%%%%%%%%%%%%% Install %%%%%%%%%%%%%%%%%%%%%%%%%%%%

install_pkg() {
    local PKG="$1"
    local FORCED_SOURCE="$2"
    local DRY_RUN="$3"

    log_info "Installing ${BOLD}$PKG${NC}..."

    if [[ -n "$FORCED_SOURCE" ]]; then
        case "$FORCED_SOURCE" in
            pacman)
                pacman_has "$PKG" || { log_err "Not found in pacman"; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via pacman"; return 0; }
                acquire_lock "pacman"
                sudo pacman -S --needed "$PKG" && db_add "$PKG" "pacman"
                release_lock "pacman"
                ;;
            aur)
                aur_has "$PKG" || { log_err "Not found in AUR"; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via AUR"; return 0; }
                acquire_lock "aur"
                sudo -u "$SUDO_USER" yay -S "$PKG" && db_add "$PKG" "aur"
                release_lock "aur"
                ;;
            debian)
                echo -e "${CYAN}→${NC} Checking Debian container..."
                apt_has "$PKG" || { log_err "Not found in Debian container"; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via Debian container"; return 0; }
                acquire_lock "debian"
                sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- sudo apt install -y "$PKG" \
                    && distrobox_export "$PKG" "$DEBIAN_BOX" \
                    && db_add "$PKG" "debian"
                release_lock "debian"
                ;;
            fedora)
                echo -e "${CYAN}→${NC} Checking Fedora container..."
                dnf_has "$PKG" || { log_err "Not found in Fedora container"; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via Fedora container"; return 0; }
                acquire_lock "fedora"
                sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf install -y "$PKG" \
                    && distrobox_export "$PKG" "$FEDORA_BOX" \
                    && db_add "$PKG" "fedora"
                release_lock "fedora"
                ;;
            *)
                log_err "Invalid source: $FORCED_SOURCE"
                return 1
                ;;
        esac
        return 0
    fi

    # Default priority order
    if pacman_has "$PKG"; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via pacman"; return 0; }
        acquire_lock "pacman"
        sudo pacman -S --needed "$PKG" && db_add "$PKG" "pacman"
        release_lock "pacman"
        return 0
    fi

    if command_exists yay && aur_has "$PKG"; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via AUR"; return 0; }
        acquire_lock "aur"
        sudo -u "$SUDO_USER" yay -S "$PKG" && db_add "$PKG" "aur"
        release_lock "aur"
        return 0
    fi

    echo -e "${CYAN}→${NC} Checking Debian container..."
    if apt_has "$PKG"; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via Debian container"; return 0; }
        acquire_lock "debian"
        sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- sudo apt install -y "$PKG" \
            && distrobox_export "$PKG" "$DEBIAN_BOX" \
            && db_add "$PKG" "debian"
        release_lock "debian"
        return 0
    fi

    echo -e "${CYAN}→${NC} Checking Fedora container..."
    if dnf_has "$PKG"; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via Fedora container"; return 0; }
        acquire_lock "fedora"
        sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf install -y "$PKG" \
            && distrobox_export "$PKG" "$FEDORA_BOX" \
            && db_add "$PKG" "fedora"
        release_lock "fedora"
        return 0
    fi

    log_err "Package '$PKG' not found anywhere."
    return 1
}

#%%%%%%%%%%%%%%%%%%%%%% Remove %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

remove_pkg() {
    local PKG="$1"
    local DRY_RUN="$2"
    local PURGE="$3"
    local FORCED_SOURCE="$4"
    local FOUND=0

    log_info "Searching for installed ${BOLD}$PKG${NC}..."

    if [[ -n "$FORCED_SOURCE" ]]; then
        case "$FORCED_SOURCE" in
            pacman)
                pacman -Qi "$PKG" &>/dev/null || { log_warn "Package '$PKG' is not installed via pacman."; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via pacman"; return 0; }
                log_info "Removing $PKG via pacman..."
                acquire_lock "pacman"
                sudo pacman -Rns "$PKG" && db_remove "$PKG"
                release_lock "pacman"
                ;;
            aur)
                command_exists yay && yay -Qi "$PKG" &>/dev/null || { log_warn "Package '$PKG' is not installed via AUR."; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via AUR"; return 0; }
                log_info "Removing $PKG via AUR..."
                acquire_lock "aur"
                sudo -u "$SUDO_USER" yay -Rns "$PKG" && db_remove "$PKG"
                release_lock "aur"
                ;;
            debian)
                sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- dpkg -s "$PKG" &>/dev/null || { log_warn "Package '$PKG' is not installed in Debian container."; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via Debian container"; return 0; }
                log_info "Removing $PKG via Debian container..."
                acquire_lock "debian"
                sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- sudo apt remove -y "$PKG" && db_remove "$PKG"
                release_lock "debian"
                [[ "$PURGE" == "1" ]] && purge_xdg_exports "$PKG"
                ;;
            fedora)
                sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- rpm -q "$PKG" &>/dev/null || { log_warn "Package '$PKG' is not installed in Fedora container."; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via Fedora container"; return 0; }
                log_info "Removing $PKG via Fedora container..."
                acquire_lock "fedora"
                sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf remove -y "$PKG" && db_remove "$PKG"
                release_lock "fedora"
                [[ "$PURGE" == "1" ]] && purge_xdg_exports "$PKG"
                ;;
            *)
                log_err "Invalid source: $FORCED_SOURCE"
                return 1
                ;;
        esac
        log_ok "$PKG removed."
        return 0
    fi

    if pacman -Qi "$PKG" &>/dev/null; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via pacman"; FOUND=1; }
        if [[ "$DRY_RUN" != "1" ]]; then
            log_info "Removing $PKG via pacman..."
            acquire_lock "pacman"
            sudo pacman -Rns "$PKG" && db_remove "$PKG"
            release_lock "pacman"
            FOUND=1
        fi
    fi

    if command_exists yay && yay -Qi "$PKG" &>/dev/null; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via AUR"; FOUND=1; }
        if [[ "$DRY_RUN" != "1" ]]; then
            log_info "Removing $PKG via AUR..."
            acquire_lock "aur"
            sudo -u "$SUDO_USER" yay -Rns "$PKG" && db_remove "$PKG"
            release_lock "aur"
            FOUND=1
        fi
    fi

    echo -e "${CYAN}→${NC} Checking Debian container..."
    if sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- dpkg -s "$PKG" &>/dev/null; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via Debian container"; FOUND=1; }
        if [[ "$DRY_RUN" != "1" ]]; then
            log_info "Removing $PKG via Debian container..."
            acquire_lock "debian"
            sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- sudo apt remove -y "$PKG" && db_remove "$PKG"
            release_lock "debian"
            [[ "$PURGE" == "1" ]] && purge_xdg_exports "$PKG"
            FOUND=1
        fi
    fi

    echo -e "${CYAN}→${NC} Checking Fedora container..."
    if sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- rpm -q "$PKG" &>/dev/null; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via Fedora container"; FOUND=1; }
        if [[ "$DRY_RUN" != "1" ]]; then
            log_info "Removing $PKG via Fedora container..."
            acquire_lock "fedora"
            sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf remove -y "$PKG" && db_remove "$PKG"
            release_lock "fedora"
            [[ "$PURGE" == "1" ]] && purge_xdg_exports "$PKG"
            FOUND=1
        fi
    fi

    if [[ $FOUND -eq 0 ]]; then
        log_warn "Package '$PKG' is not installed anywhere."
        return 1
    fi

    [[ "$DRY_RUN" != "1" ]] && log_ok "$PKG removed."
    return 0
}

#%%%%%%%%%%%%%%%%%%%%%% Update %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

update_all() {
    # Build pinned list for reference during update
    local pinned_list=""
    if [[ -f "$PINS_FILE" ]] && [[ -s "$PINS_FILE" ]]; then
        pinned_list="$(cat "$PINS_FILE")"
        log_info "Pinned packages (will be skipped): $(echo "$pinned_list" | tr '\n' ' ')"
    fi

    log_info "Updating Arch packages..."
    acquire_lock "pacman"
    sudo pacman -Syu || { log_err "pacman update failed. Aborting."; release_lock "pacman"; exit 1; }
    release_lock "pacman"

    # Re-pin any pinned packages that pacman may have updated
    if [[ -n "$pinned_list" ]]; then
        while IFS= read -r pkg; do
            [[ -z "$pkg" ]] && continue
            if pacman -Qi "$pkg" &>/dev/null; then
                local installed_ver available_ver
                installed_ver="$(pacman -Qi "$pkg" 2>/dev/null | awk '/^Version/ {print $3}')"
                available_ver="$(pacman -Si "$pkg" 2>/dev/null | awk '/^Version/ {print $3}')"
                if [[ -n "$available_ver" && "$installed_ver" != "$available_ver" ]]; then
                    # Downgrade back to installed version by ignoring — pacman already ran
                    # so just note it was skipped in the log
                    log_info "Skipped pinned package: $pkg"
                fi
            fi
        done <<< "$pinned_list"
    fi

    if command_exists yay; then
        log_info "Updating AUR packages..."
        acquire_lock "aur"
        # Build ignore list for yay from pinned packages
        local ignore_args=()
        if [[ -n "$pinned_list" ]]; then
            while IFS= read -r pkg; do
                [[ -z "$pkg" ]] && continue
                ignore_args+=(--ignore "$pkg")
            done <<< "$pinned_list"
        fi
        sudo -u "$SUDO_USER" yay -Syu "${ignore_args[@]}" \
            || { log_err "yay update failed. Aborting."; release_lock "aur"; exit 1; }
        release_lock "aur"
    fi

    log_info "Updating Debian container..."
    acquire_lock "debian"
    sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- bash -c "sudo apt update && sudo apt upgrade -y" \
        || { log_err "Debian update failed. Aborting."; release_lock "debian"; exit 1; }
    release_lock "debian"

    log_info "Updating Fedora container..."
    acquire_lock "fedora"
    sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf upgrade -y \
        || { log_err "Fedora update failed. Aborting."; release_lock "fedora"; exit 1; }
    release_lock "fedora"

    log_ok "Update complete."
}

#%%%%%%%%%%%%%%%%%%%%%% List %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

list_pkgs() {
    local FILTER_SOURCE="$1"
    local PROFILE="$2"

    # Profile listing mode
    if [[ -n "$PROFILE" ]]; then
        local DEST="$PROFILES_DIR/$PROFILE.csv"
        if [[ ! -f "$DEST" ]]; then
            log_err "Profile '$PROFILE' does not exist."
            return 1
        fi

        echo -e "\n${BOLD}Profile: $PROFILE${NC}\n"
        printf "  ${BOLD}%-30s %-10s %s${NC}\n" "Package" "Source" "Status"
        echo "  $(printf '%.0s─' {1..55})"

        while IFS=',' read -r pkg source date user; do
            [[ "$pkg" == "package" ]] && continue
            # Check if installed via DB
            local status
            if db_get "$pkg" &>/dev/null && [[ -n "$(db_get "$pkg")" ]]; then
                status="${GREEN}installed${NC}"
            else
                status="${YELLOW}not installed${NC}"
            fi
            printf "  %-30s %-10s " "$pkg" "$source"
            echo -e "$status"
        done < "$DEST"

        echo ""
        return 0
    fi

    # Normal listing mode
    if [[ ! -f "$DB_FILE" ]] || [[ $(wc -l < "$DB_FILE") -le 1 ]]; then
        echo -e "${YELLOW}No packages tracked yet.${NC}"
        return 0
    fi

    echo -e "\n${BOLD}Magnet-managed packages:${NC}\n"
    printf "  ${BOLD}%-30s %-10s %-20s %s${NC}\n" "Package" "Source" "Date" "User"
    echo "  $(printf '%.0s─' {1..70})"

    while IFS=',' read -r pkg source date user; do
        [[ "$pkg" == "package" ]] && continue
        [[ -n "$FILTER_SOURCE" && "$source" != "$FILTER_SOURCE" ]] && continue
        local pin_marker=""
        is_pinned "$pkg" && pin_marker=" ${YELLOW}[pinned]${NC}"
        printf "  %-30s %-10s %-20s %s" "$pkg" "$source" "$date" "$user"
        echo -e "$pin_marker"
    done < "$DB_FILE"

    echo ""
}

#%%%%%%%%%%%%%%%%%%%%%% Info %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

info_pkg() {
    local PKG="$1"
    local row
    row="$(db_get "$PKG")"

    if [[ -z "$row" ]]; then
        log_warn "$PKG is not tracked by Magnet."
        return 1
    fi

    local source date user
    source="$(echo "$row" | cut -d',' -f2)"
    date="$(echo "$row" | cut -d',' -f3)"
    user="$(echo "$row" | cut -d',' -f4)"

    echo -e "\n${BOLD}$PKG${NC}"
    echo -e "  ${CYAN}Source:${NC}   $source"
    echo -e "  ${CYAN}Installed:${NC} $date"
    echo -e "  ${CYAN}By:${NC}       $user\n"
}

#%%%%%%%%%%%%%%%%%%%%%% Why %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

why_pkg() {
    local PKG="$1"
    local row
    row="$(db_get "$PKG")"

    if [[ -z "$row" ]]; then
        log_warn "$PKG is not tracked by Magnet. It may have been installed outside of Magnet."
        return 1
    fi

    local user date source
    user="$(echo "$row" | cut -d',' -f4)"
    date="$(echo "$row" | cut -d',' -f3)"
    source="$(echo "$row" | cut -d',' -f2)"

    echo -e "\n  ${BOLD}$PKG${NC} was installed by ${GREEN}$user${NC} on ${CYAN}$date${NC} from ${YELLOW}$source${NC}.\n"
}

#%%%%%%%%%%%%%%%%%%%%%% Export %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

export_pkgs() {
    local PROFILE="$1"
    local DEST="$PROFILES_DIR/$PROFILE.csv"

    if [[ ! -f "$DB_FILE" ]] || [[ $(wc -l < "$DB_FILE") -le 1 ]]; then
        log_warn "No packages to export."
        return 1
    fi

    cp "$DB_FILE" "$DEST"
    log_ok "Exported to $DEST"
}

#%%%%%%%%%%%%%%%%%%%%%% Import %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

import_pkgs() {
    local PROFILE="$1"
    local SRC="$PROFILES_DIR/$PROFILE.csv"

    if [[ ! -f "$SRC" ]]; then
        log_err "Profile '$PROFILE' not found at $SRC"
        return 1
    fi

    log_info "Importing profile ${BOLD}$PROFILE${NC}..."

    local FAILED=()
    while IFS=',' read -r pkg source date user; do
        [[ "$pkg" == "package" ]] && continue  # skip header
        log_info "Installing $pkg from $source..."
        if ! install_pkg "$pkg" "$source" "0"; then
            FAILED+=("$pkg")
        fi
    done < "$SRC"

    if [[ ${#FAILED[@]} -gt 0 ]]; then
        log_err "Failed to install: ${FAILED[*]}"
        return 1
    fi

    log_ok "Profile '$PROFILE' imported successfully."
}

#%%%%%%%%%%%%%%%%%%%%%% Add Profile %%%%%%%%%%%%%%%%%%%%%%%%

add_profile() {
    local PROFILE="$1"
    local DEST="$PROFILES_DIR/$PROFILE.csv"

    if [[ -f "$DEST" ]]; then
        log_warn "Profile '$PROFILE' already exists."
        local answer
        read -rp "$(echo -e "  ${BOLD}Overwrite? [y/N]:${NC} ")" answer
        if [[ "$answer" != "y" && "$answer" != "Y" ]]; then
            log_info "Aborted."
            return 1
        fi
    fi

    echo "package,source,date,user" > "$DEST"
    log_ok "Profile '$PROFILE' created at $DEST"
}

#%%%%%%%%%%%%%%%%%%%%%% Remove Profile %%%%%%%%%%%%%%%%%%%%%

remove_profile() {
    local PROFILE="$1"
    local DEST="$PROFILES_DIR/$PROFILE.csv"

    if [[ ! -f "$DEST" ]]; then
        log_warn "Profile '$PROFILE' does not exist."
        return 1
    fi

    rm -f "$DEST"
    log_ok "Profile '$PROFILE' removed."
}

#%%%%%%%%%%%%%%%%%%%%%% Profile Add %%%%%%%%%%%%%%%%%%%%%%%%

profile_add() {
    local PROFILE="$1"
    local PKG="$2"
    local SOURCE="$3"
    local DEST="$PROFILES_DIR/$PROFILE.csv"

    if [[ ! -f "$DEST" ]]; then
        log_err "Profile '$PROFILE' does not exist. Create it first with: magnet add-profile $PROFILE"
        return 1
    fi

    # Check if package already exists in profile (any source)
    if grep -q "^$PKG," "$DEST" 2>/dev/null; then
        local existing_source
        existing_source="$(grep "^$PKG," "$DEST" | cut -d',' -f2)"
        log_warn "$PKG is already in profile '$PROFILE' (source: $existing_source). Remove it first."
        return 1
    fi

    # Validate source
    case "$SOURCE" in
        pacman|aur|debian|fedora) ;;
        *)
            log_err "Invalid source '$SOURCE'. Must be one of: pacman, aur, debian, fedora"
            return 1
            ;;
    esac

    local date
    date="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "$PKG,$SOURCE,$date,$SUDO_USER" >> "$DEST"
    log_ok "Added $PKG ($SOURCE) to profile '$PROFILE'."
}

#%%%%%%%%%%%%%%%%%%%%%% Profile Remove %%%%%%%%%%%%%%%%%%%%%

profile_remove() {
    local PROFILE="$1"
    local PKG="$2"
    local DEST="$PROFILES_DIR/$PROFILE.csv"

    if [[ ! -f "$DEST" ]]; then
        log_err "Profile '$PROFILE' does not exist."
        return 1
    fi

    if ! grep -q "^$PKG," "$DEST" 2>/dev/null; then
        log_warn "$PKG is not in profile '$PROFILE'."
        return 1
    fi

    local tmp
    tmp="$(mktemp)"
    grep -v "^$PKG," "$DEST" > "$tmp" || true
    mv "$tmp" "$DEST"
    log_ok "Removed $PKG from profile '$PROFILE'."
}



#%%%%%%%%%%%%%%%%%%%%%% Doctor %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

doctor() {
    local ISSUES=0

    echo -e "\n${BOLD}Magnet Doctor${NC}\n"

    # Check yay
    echo -e "${CYAN}→${NC} Checking yay..."
    if ! command_exists yay; then
        log_warn "yay is not installed. AUR support will not work."
        echo -e "  ${CYAN}Attempting to install yay...${NC}"
        if command_exists git && command_exists makepkg; then
            sudo -u "$SUDO_USER" bash -c "
                cd /tmp && git clone https://aur.archlinux.org/yay.git yay-doctor &&
                cd yay-doctor && makepkg -si --noconfirm &&
                cd .. && rm -rf yay-doctor
            " && log_ok "yay installed." || { log_err "Failed to install yay. Install it manually."; ((ISSUES++)); }
        else
            log_err "git or makepkg missing — cannot install yay automatically."
            ((ISSUES++))
        fi
    else
        log_ok "yay found."
    fi

    # Check distrobox
    echo -e "${CYAN}→${NC} Checking distrobox..."
    if ! command_exists distrobox; then
        log_warn "distrobox is not installed. Container support will not work."
        echo -e "  ${CYAN}Attempting to install distrobox...${NC}"
        sudo pacman -S --noconfirm distrobox \
            && log_ok "distrobox installed." \
            || { log_err "Failed to install distrobox."; ((ISSUES++)); }
    else
        log_ok "distrobox found."
    fi

    # Check Debian container
    echo -e "${CYAN}→${NC} Checking Debian container ($DEBIAN_BOX)..."
    if ! distrobox list 2>/dev/null | grep -q "$DEBIAN_BOX"; then
        log_warn "Debian container '$DEBIAN_BOX' not found."
        echo -e "  ${CYAN}Attempting to create it...${NC}"
        sudo -u "$SUDO_USER" distrobox create --name "$DEBIAN_BOX" --image debian:latest \
            && log_ok "Debian container created." \
            || { log_err "Failed to create Debian container."; ((ISSUES++)); }
    else
        log_ok "Debian container found."
    fi

    # Check Fedora container
    echo -e "${CYAN}→${NC} Checking Fedora container ($FEDORA_BOX)..."
    if ! distrobox list 2>/dev/null | grep -q "$FEDORA_BOX"; then
        log_warn "Fedora container '$FEDORA_BOX' not found."
        echo -e "  ${CYAN}Attempting to create it...${NC}"
        sudo -u "$SUDO_USER" distrobox create --name "$FEDORA_BOX" --image fedora:latest \
            && log_ok "Fedora container created." \
            || { log_err "Failed to create Fedora container."; ((ISSUES++)); }
    else
        log_ok "Fedora container found."
    fi

    # Check DB integrity
    echo -e "${CYAN}→${NC} Checking database..."
    if [[ ! -f "$DB_FILE" ]]; then
        log_warn "Database file missing at $DB_FILE."
        echo -e "  ${CYAN}Recreating...${NC}"
        mkdir -p "$DB_DIR"
        echo "package,source,date,user" > "$DB_FILE"
        log_ok "Database recreated."
    else
        local total
        total=$(( $(wc -l < "$DB_FILE") - 1 ))
        log_ok "Database intact — $total package(s) tracked."
    fi

    # Check for orphaned DB entries
    echo -e "${CYAN}→${NC} Checking for orphaned database entries..."
    local ORPHANS=()
    while IFS=',' read -r pkg source date user; do
        [[ "$pkg" == "package" ]] && continue
        case "$source" in
            pacman|aur)
                pacman -Qi "$pkg" &>/dev/null || ORPHANS+=("$pkg ($source)")
                ;;
        esac
    done < "$DB_FILE"

    if [[ ${#ORPHANS[@]} -gt 0 ]]; then
        log_warn "Orphaned DB entries found (installed outside Magnet or manually removed):"
        for o in "${ORPHANS[@]}"; do
            echo -e "    ${YELLOW}→ $o${NC}"
        done
        echo -e "  ${CYAN}Removing orphaned entries from DB...${NC}"
        for o in "${ORPHANS[@]}"; do
            local pkg_name
            pkg_name="$(echo "$o" | cut -d' ' -f1)"
            db_remove "$pkg_name"
        done
        log_ok "Orphaned entries removed."
    else
        log_ok "No orphaned entries found."
    fi

    # Check lock dir
    echo -e "${CYAN}→${NC} Checking lock directory..."
    if [[ ! -d "$LOCK_DIR" ]]; then
        log_warn "Lock directory missing. Recreating..."
        mkdir -p "$LOCK_DIR"
        log_ok "Lock directory created."
    else
        log_ok "Lock directory OK."
    fi

    echo ""
    if [[ $ISSUES -eq 0 ]]; then
        log_ok "All checks passed. Magnet is healthy."
    else
        log_warn "$ISSUES issue(s) could not be fixed automatically. Check the output above."
    fi
    echo ""
}

show_log() {
    if [[ ! -f "$LOGFILE" ]]; then
        log_warn "No log file found at $LOGFILE"
        return 0
    fi

    echo -e "\n${BOLD}Magnet Log${NC}\n"

    while IFS= read -r line; do
        if [[ "$line" == *"✔"* ]] || [[ "$line" == *"complete"* ]] || [[ "$line" == *"Finished"* ]]; then
            echo -e "  ${GREEN}$line${NC}"
        elif [[ "$line" == *"✘"* ]] || [[ "$line" == *"failed"* ]] || [[ "$line" == *"Error"* ]]; then
            echo -e "  ${RED}$line${NC}"
        elif [[ "$line" == *"⚠"* ]] || [[ "$line" == *"warn"* ]]; then
            echo -e "  ${YELLOW}$line${NC}"
        else
            echo -e "  ${CYAN}$line${NC}"
        fi
    done < "$LOGFILE"

    echo ""
}

#%%%%%%%%%%%%%%%%%%%%%%%%%% CLI %%%%%%%%%%%%%%%%%%%%%%%%%%%%

case "$1" in

    install)
        shift

        SOURCE=""
        DRY_RUN="0"
        PACKAGES=()

        for arg in "$@"; do
            if [[ "$arg" == --source=* ]]; then
                SOURCE="${arg#--source=}"
            elif [[ "$arg" == "--dry-run" ]]; then
                DRY_RUN="1"
            else
                PACKAGES+=("$arg")
            fi
        done

        if [[ ${#PACKAGES[@]} -eq 0 ]]; then
            echo -e "${RED}Error:${NC} No packages specified."
            exit 1
        fi

        [[ "$DRY_RUN" == "1" ]] && echo -e "\n${YELLOW}Dry run — no changes will be made.${NC}\n"

        FAILED=()
        for pkg in "${PACKAGES[@]}"; do
            if ! install_pkg "$pkg" "$SOURCE" "$DRY_RUN"; then
                FAILED+=("$pkg")
            fi
        done

        if [[ ${#FAILED[@]} -gt 0 ]]; then
            echo ""
            log_err "Failed to install: ${FAILED[*]}"
            exit 1
        fi
        ;;

    remove)
        shift

        DRY_RUN="0"
        PURGE="1"
        SOURCE=""
        PACKAGES=()

        for arg in "$@"; do
            if [[ "$arg" == "--dry-run" ]]; then
                DRY_RUN="1"
            elif [[ "$arg" == "--no-purge" ]]; then
                PURGE="0"
            elif [[ "$arg" == --source=* ]]; then
                SOURCE="${arg#--source=}"
            else
                PACKAGES+=("$arg")
            fi
        done

        if [[ ${#PACKAGES[@]} -eq 0 ]]; then
            echo -e "${RED}Error:${NC} No packages specified."
            exit 1
        fi

        [[ "$DRY_RUN" == "1" ]] && echo -e "\n${YELLOW}Dry run — no changes will be made.${NC}\n"
        [[ "$PURGE" == "0" ]] && echo -e "\n${YELLOW}Note: XDG export artifacts will not be purged.${NC}\n"

        FAILED=()
        for pkg in "${PACKAGES[@]}"; do
            if ! remove_pkg "$pkg" "$DRY_RUN" "$PURGE" "$SOURCE"; then
                FAILED+=("$pkg")
            fi
        done

        if [[ ${#FAILED[@]} -gt 0 ]]; then
            echo ""
            log_err "Not found / failed to remove: ${FAILED[*]}"
            exit 1
        fi
        ;;

    search)
        search_pkg "$2"
        ;;

    update)
        update_all
        ;;

    list)
        FILTER=""
        PROFILE=""
        if [[ "${2:-}" == --source=* ]]; then
            FILTER="${2#--source=}"
        elif [[ "${2:-}" == --profile=* ]]; then
            PROFILE="${2#--profile=}"
        fi
        list_pkgs "$FILTER" "$PROFILE"
        ;;

    info)
        info_pkg "$2"
        ;;

    why)
        why_pkg "$2"
        ;;

    add-profile)
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error:${NC} No profile name specified."
            exit 1
        fi
        add_profile "$2"
        ;;

    remove-profile)
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error:${NC} No profile name specified."
            exit 1
        fi
        remove_profile "$2"
        ;;

    profile-add)
        if [[ -z "${2:-}" || -z "${3:-}" || -z "${4:-}" ]]; then
            echo -e "${RED}Error:${NC} Usage: magnet profile-add <profile> <package> --source=<source>"
            exit 1
        fi
        SOURCE=""
        for arg in "${@:4}"; do
            if [[ "$arg" == --source=* ]]; then
                SOURCE="${arg#--source=}"
            fi
        done
        if [[ -z "$SOURCE" ]]; then
            echo -e "${RED}Error:${NC} --source is required for profile-add."
            exit 1
        fi
        profile_add "$2" "$3" "$SOURCE"
        ;;

    profile-remove)
        if [[ -z "${2:-}" || -z "${3:-}" ]]; then
            echo -e "${RED}Error:${NC} Usage: magnet profile-remove <profile> <package>"
            exit 1
        fi
        profile_remove "$2" "$3"
        ;;

    export)
        export_pkgs "$2"
        ;;

    import)
        import_pkgs "$2"
        ;;

    pin)
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error:${NC} No package specified."
            exit 1
        fi
        pin_pkg "$2"
        ;;

    unpin)
        if [[ -z "${2:-}" ]]; then
            echo -e "${RED}Error:${NC} No package specified."
            exit 1
        fi
        unpin_pkg "$2"
        ;;

    doctor)
        doctor
        ;;

    log)
        show_log
        ;;

    -h|--help)
        echo -e "
${BOLD}Magnet${NC} — Package Management Wrapper v0.6

${BOLD}Usage:${NC}
  magnet install        [--source=pacman|aur|debian|fedora] [--dry-run] <pkg> [pkg2 ...]
  magnet remove         [--source=pacman|aur|debian|fedora] [--dry-run] [--no-purge] <pkg> [pkg2 ...]
  magnet search         <pkg>
  magnet update
  magnet list           [--source=pacman|aur|debian|fedora]
  magnet list           --profile=<name>
  magnet info           <pkg>
  magnet why            <pkg>
  magnet pin            <pkg>
  magnet unpin          <pkg>
  magnet export         <profile>
  magnet import         <profile>
  magnet add-profile    <profile>
  magnet remove-profile <profile>
  magnet profile-add    <profile> <pkg> --source=pacman|aur|debian|fedora
  magnet profile-remove <profile> <pkg>
  magnet doctor
  magnet log

${BOLD}Notes:${NC}
  --source      Force a specific package manager (install priority:
                pacman → AUR → Debian → Fedora)
  --no-purge    Skip XDG desktop entry/icon cleanup on remove (container packages only)
  --dry-run     Preview what would happen without making any changes
  pin/unpin     Pinned packages are silently skipped during magnet update
"
        ;;

    *)
        log_err "Unknown command '$1'. Run 'magnet --help' for usage."
        exit 1
        ;;
esac
