#!/usr/bin/env bash
set -uo pipefail

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
#  Magnet Package Management Wrapper  #
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

LOGFILE="/var/log/magnet.log"

log() {
    echo "[MAGNET] $1"
    echo "[MAGNET] $1" >> "$LOGFILE" 2>/dev/null || true
}

if [[ -z "${SUDO_USER:-}" ]]; then
    echo "Error: Must be run with sudo."
    exit 1
fi

if [[ -z "${2:-}" && "$1" != "update" ]]; then
    echo "Error: Missing package name."
    exit 1
fi

#%%%%%%%%%%%%%%%%%%%%% Config %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

DEBIAN_BOX="magnet-debian"
FEDORA_BOX="magnet-fedora"

LOCK_DIR="/tmp/magnet-locks"
mkdir -p "$LOCK_DIR"

#%%%%%%%%%%%%%%%%%%%%% Lock Helpers %%%%%%%%%%%%%%%%%%%%%%%%

acquire_lock() {
    local name="$1"
    local lockfile="$LOCK_DIR/$name.lock"
    exec {_LOCK_FD}>"$lockfile"
    if ! flock -n "$_LOCK_FD"; then
        echo "Error: Another magnet operation is already using $name. Aborting."
        exit 1
    fi
}

release_lock() {
    local name="$1"
    local lockfile="$LOCK_DIR/$name.lock"
    flock -u "$_LOCK_FD"
    rm -f "$lockfile"
}

#%%%%%%%%%%%%%%%%%%%%% Helpers %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

pacman_has() {
    pacman -Si "$1" &>/dev/null
}

aur_has() {
    sudo -u "$SUDO_USER" yay -Si "$1" &>/dev/null
}

apt_has() {
    sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- apt-cache show "$1" &>/dev/null
}

dnf_has() {
    sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- dnf search "$1" &>/dev/null
}

#%%%%%%%%%%%%%%%%%%%%%% Search %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

search_pkg() {
    PKG="$1"
    FOUND=0

    log "Searching for $PKG..."

    if pacman_has "$PKG"; then
        echo "✔ Found in pacman (Arch)"
        FOUND=1
    fi

    if command_exists yay && aur_has "$PKG"; then
        echo "✔ Found in AUR"
        FOUND=1
    fi

    if apt_has "$PKG"; then
        echo "✔ Found in Debian container"
        FOUND=1
    fi

    if dnf_has "$PKG"; then
        echo "✔ Found in Fedora container"
        FOUND=1
    fi

    if [[ $FOUND -eq 0 ]]; then
        echo "✘ Package not found anywhere."
        exit 1
    fi
}

#%%%%%%%%%%%%%%%%%%%%%% Install %%%%%%%%%%%%%%%%%%%%%%%%%%%%

install_pkg() {
    local PKG="$1"
    local FORCED_SOURCE="$2"

    log "Installing $PKG..."

    if [[ -n "$FORCED_SOURCE" ]]; then
        case "$FORCED_SOURCE" in
            pacman)
                pacman_has "$PKG" || { echo "Not found in pacman"; return 1; }
                acquire_lock "pacman"
                sudo pacman -S --needed "$PKG"
                release_lock "pacman"
                ;;
            aur)
                aur_has "$PKG" || { echo "Not found in AUR"; return 1; }
                acquire_lock "aur"
                sudo -u "$SUDO_USER" yay -S "$PKG"
                release_lock "aur"
                ;;
            debian)
                apt_has "$PKG" || { echo "Not found in Debian container"; return 1; }
                acquire_lock "debian"
                sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- sudo apt install -y "$PKG"
                release_lock "debian"
                ;;
            fedora)
                dnf_has "$PKG" || { echo "Not found in Fedora container"; return 1; }
                acquire_lock "fedora"
                sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf install -y "$PKG"
                release_lock "fedora"
                ;;
            *)
                echo "Invalid source: $FORCED_SOURCE"
                return 1
                ;;
        esac
        return 0
    fi

    # Default priority order
    if pacman_has "$PKG"; then
        acquire_lock "pacman"
        sudo pacman -S --needed "$PKG"
        release_lock "pacman"
        return 0
    fi

    if command_exists yay && aur_has "$PKG"; then
        acquire_lock "aur"
        sudo -u "$SUDO_USER" yay -S "$PKG"
        release_lock "aur"
        return 0
    fi

    if apt_has "$PKG"; then
        acquire_lock "debian"
        sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- sudo apt install -y "$PKG"
        release_lock "debian"
        return 0
    fi

    if dnf_has "$PKG"; then
        acquire_lock "fedora"
        sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf install -y "$PKG"
        release_lock "fedora"
        return 0
    fi

    echo "Package '$PKG' not found anywhere."
    return 1
}

#%%%%%%%%%%%%%%%%%%%%%% Remove %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

remove_pkg() {
    local PKG="$1"
    local FOUND=0

    log "Searching for installed $PKG..."

    if pacman -Qi "$PKG" &>/dev/null; then
        log "Removing $PKG via pacman..."
        acquire_lock "pacman"
        sudo pacman -Rns "$PKG"
        release_lock "pacman"
        FOUND=1
    fi

    if command_exists yay && yay -Qi "$PKG" &>/dev/null; then
        log "Removing $PKG via AUR..."
        acquire_lock "aur"
        sudo -u "$SUDO_USER" yay -Rns "$PKG"
        release_lock "aur"
        FOUND=1
    fi

    if sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- dpkg -s "$PKG" &>/dev/null; then
        log "Removing $PKG via Debian container..."
        acquire_lock "debian"
        sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- sudo apt remove -y "$PKG"
        release_lock "debian"
        FOUND=1
    fi

    if sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- rpm -q "$PKG" &>/dev/null; then
        log "Removing $PKG via Fedora container..."
        acquire_lock "fedora"
        sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf remove -y "$PKG"
        release_lock "fedora"
        FOUND=1
    fi

    if [[ $FOUND -eq 0 ]]; then
        log "Package '$PKG' is not installed anywhere."
        return 1
    fi

    log "$PKG removed."
    return 0
}

#%%%%%%%%%%%%%%%%%%%%%% Update %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

update_all() {
    log "Updating Arch packages..."
    acquire_lock "pacman"
    sudo pacman -Syu || { log "pacman update failed. Aborting."; release_lock "pacman"; exit 1; }
    release_lock "pacman"

    if command_exists yay; then
        log "Updating AUR (yay) packages..."
        acquire_lock "aur"
        sudo -u "$SUDO_USER" yay -Syu || { log "yay update failed. Aborting."; release_lock "aur"; exit 1; }
        release_lock "aur"
    fi

    log "Updating Debian container..."
    acquire_lock "debian"
    sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- bash -c "sudo apt update && sudo apt upgrade -y" \
        || { log "Debian update failed. Aborting."; release_lock "debian"; exit 1; }
    release_lock "debian"

    log "Updating Fedora container..."
    acquire_lock "fedora"
    sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf upgrade -y \
        || { log "Fedora update failed. Aborting."; release_lock "fedora"; exit 1; }
    release_lock "fedora"

    log "Update complete."
}

#%%%%%%%%%%%%%%%%%%%%%%%%%% CLI %%%%%%%%%%%%%%%%%%%%%%%%%%%%

case "$1" in

    install)
        shift

        SOURCE=""
        PACKAGES=()

        for arg in "$@"; do
            if [[ "$arg" == --source=* ]]; then
                SOURCE="${arg#--source=}"
            else
                PACKAGES+=("$arg")
            fi
        done

        if [[ ${#PACKAGES[@]} -eq 0 ]]; then
            echo "No packages specified."
            exit 1
        fi

        FAILED=()
        for pkg in "${PACKAGES[@]}"; do
            if ! install_pkg "$pkg" "$SOURCE"; then
                FAILED+=("$pkg")
            fi
        done

        if [[ ${#FAILED[@]} -gt 0 ]]; then
            echo ""
            log "Failed to install: ${FAILED[*]}"
            exit 1
        fi
        ;;

    remove)
        shift

        if [[ $# -eq 0 ]]; then
            echo "No packages specified."
            exit 1
        fi

        FAILED=()
        for pkg in "$@"; do
            if ! remove_pkg "$pkg"; then
                FAILED+=("$pkg")
            fi
        done

        if [[ ${#FAILED[@]} -gt 0 ]]; then
            echo ""
            log "Not found / failed to remove: ${FAILED[*]}"
            exit 1
        fi
        ;;

    search)
        search_pkg "$2"
        ;;

    update)
        update_all
        ;;

    *)
        echo "Magnet Package Management Wrapper"
        echo ""
        echo "Usage:"
        echo "  magnet install [--source=pacman|aur|debian|fedora] <pkg> [pkg2 ...]"
        echo "  magnet remove <pkg> [pkg2 ...]"
        echo "  magnet search <pkg>"
        echo "  magnet update"
        ;;
esac
