#!/usr/bin/env bash
set -uo pipefail

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
#  Magnet Package Management Wrapper  v0.5               #
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

#%%%%%%%%%%%%%%%%%%%%% Color %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

#%%%%%%%%%%%%%%%%%%%%% Config %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

LOGFILE="/var/log/magnet.log"
DB_DIR="/var/lib/magnet"
DB_FILE="$DB_DIR/packages.csv"
PROFILES_DIR="$DB_DIR/profiles"
LOCK_DIR="/tmp/magnet-locks"

DEBIAN_BOX="magnet-debian"
FEDORA_BOX="magnet-fedora"

# XDG paths for desktop entry cleanup (run as SUDO_USER)
XDG_APPS="${HOME}/.local/share/applications"
XDG_ICONS="${HOME}/.local/share/icons"
XDG_DATA="${HOME}/.local/share"

#%%%%%%%%%%%%%%%%%%%%% Init %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

mkdir -p "$LOCK_DIR"
mkdir -p "$DB_DIR"
mkdir -p "$PROFILES_DIR"
trap 'rm -f "$LOCK_DIR"/*.lock' EXIT INT TERM

# Create CSV with header if it doesn't exist
if [[ ! -f "$DB_FILE" ]]; then
    echo "package,source,date,user" > "$DB_FILE"
fi

#%%%%%%%%%%%%%%%%%%%%% Guards %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

if [[ -z "${SUDO_USER:-}" ]]; then
    echo -e "${RED}Error:${NC} Must be run with sudo."
    exit 1
fi

if [[ $# -eq 0 ]]; then
    echo -e "${RED}Error:${NC} No command given."
    exit 1
fi

if [[ -z "${2:-}" ]] && [[ "$1" != "update" ]] && [[ "$1" != "log" ]] && [[ "$1" != "list" ]]; then
    echo -e "${RED}Error:${NC} Missing argument."
    exit 1
fi

#%%%%%%%%%%%%%%%%%%%%% Logging %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

log() {
    local timestamp
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    echo -e "[MAGNET] $1"
    echo "[$timestamp] $1" >> "$LOGFILE" 2>/dev/null || true
}

log_ok()   { log "${GREEN}✔${NC} $1"; }
log_warn() { log "${YELLOW}⚠${NC}  $1"; }
log_err()  { log "${RED}✘${NC} $1"; }
log_info() { log "${CYAN}→${NC} $1"; }

#%%%%%%%%%%%%%%%%%%%%% Database %%%%%%%%%%%%%%%%%%%%%%%%%%%%

db_add() {
    local pkg="$1" source="$2"
    local date user
    date="$(date '+%Y-%m-%d %H:%M:%S')"
    user="$SUDO_USER"
    # Remove any existing entry for this package first
    db_remove "$pkg"
    echo "$pkg,$source,$date,$user" >> "$DB_FILE"
}

db_remove() {
    local pkg="$1"
    if [[ -f "$DB_FILE" ]]; then
        local tmp
        tmp="$(mktemp)"
        grep -v "^$pkg," "$DB_FILE" > "$tmp" || true
        mv "$tmp" "$DB_FILE"
    fi
}

db_get() {
    local pkg="$1"
    grep "^$pkg," "$DB_FILE" 2>/dev/null | head -1
}

db_source() {
    local pkg="$1"
    db_get "$pkg" | cut -d',' -f2
}

#%%%%%%%%%%%%%%%%%%%%% Lock Helpers %%%%%%%%%%%%%%%%%%%%%%%%

declare -A LOCK_FDS

acquire_lock() {
    local name="$1"
    local lockfile="$LOCK_DIR/$name.lock"
    local fd

    # Defensively ensure lock dir exists regardless of startup state
    mkdir -p "$LOCK_DIR" || {
        log_err "Could not create lock directory $LOCK_DIR"
        exit 1
    }

    exec {fd}>"$lockfile" || {
        log_err "Could not create lockfile $lockfile"
        exit 1
    }

    LOCK_FDS[$name]=$fd

    if ! flock -n "${LOCK_FDS[$name]}"; then
        log_err "Another magnet operation is already using $name. Aborting."
        exit 1
    fi
}

release_lock() {
    local name="$1"
    flock -u "${LOCK_FDS[$name]}"
    rm -f "$LOCK_DIR/$name.lock"
    unset "LOCK_FDS[$name]"
}

#%%%%%%%%%%%%%%%%%%%%% Helpers %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

pacman_has() {
    pacman -Si "$1" &>/dev/null
}

aur_has() {
    sudo -u "$SUDO_USER" yay -Si "$1" &>/dev/null
}

apt_has() {
    sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- apt-cache show "$1" &>/dev/null
}

dnf_has() {
    sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- dnf search "$1" &>/dev/null
}

# Resolve a package name or app ID to a Flatpak application ID.
# Tries exact name match first, then exact app ID match.
# Returns the app ID on stdout, or returns 1 if not found.
flatpak_resolve() {
    local PKG="$1"

    if ! command_exists flatpak; then
        return 1
    fi

    # flatpak search outputs: Name \t Description \t AppID \t Version \t Branch \t Remotes
    # Try exact Name match first (case-insensitive)
    local match
    match="$(flatpak search --columns=name,application "$PKG" 2>/dev/null \
        | awk -F'\t' -v pkg="$PKG" 'tolower($1) == tolower(pkg) { print $2; exit }')"

    if [[ -n "$match" ]]; then
        echo "$match"
        return 0
    fi

    # Fall back to exact application ID match
    match="$(flatpak search --columns=name,application "$PKG" 2>/dev/null \
        | awk -F'\t' -v pkg="$PKG" 'tolower($2) == tolower(pkg) { print $2; exit }')"

    if [[ -n "$match" ]]; then
        echo "$match"
        return 0
    fi

    return 1
}

flatpak_has() {
    flatpak_resolve "$1" &>/dev/null
}

#%%%%%%%%%%%%%%%%%%%%%% Distrobox Export %%%%%%%%%%%%%%%%%%%

# Export an app from a container to the host app menu.
# Silently skips if no .desktop file is found for the package.
distrobox_export() {
    local PKG="$1"
    local BOX="$2"

    log_info "Exporting $PKG from $BOX to host..."
    sudo -u "$SUDO_USER" distrobox enter "$BOX" -- \
        distrobox-export --app "$PKG" 2>/dev/null || {
        log_warn "Could not export $PKG from $BOX (no .desktop file found — skipping)"
    }
}

# Remove all XDG desktop entries, icons, and data dirs left behind
# by a distrobox-exported app. Searches all standard XDG locations.
purge_xdg_exports() {
    local PKG="$1"
    local USER_HOME
    USER_HOME="$(getent passwd "$SUDO_USER" | cut -d: -f6)"

    log_info "Purging XDG export artifacts for $PKG..."

    local PURGED=0

    # Desktop entries — ~/.local/share/applications and /usr/share/applications
    local desktop_dirs=(
        "$USER_HOME/.local/share/applications"
        "/usr/share/applications"
        "/usr/local/share/applications"
    )
    for dir in "${desktop_dirs[@]}"; do
        while IFS= read -r -d '' f; do
            log_info "Removing desktop entry: $f"
            rm -f "$f"
            PURGED=1
        done < <(find "$dir" -maxdepth 1 -iname "*${PKG}*" -print0 2>/dev/null)
    done

    # Icons — all standard XDG icon theme directories
    local icon_dirs=(
        "$USER_HOME/.local/share/icons"
        "/usr/share/icons"
        "/usr/share/pixmaps"
    )
    for dir in "${icon_dirs[@]}"; do
        while IFS= read -r -d '' f; do
            log_info "Removing icon: $f"
            rm -f "$f"
            PURGED=1
        done < <(find "$dir" -iname "*${PKG}*" -print0 2>/dev/null)
    done

    # App data dirs left by distrobox-export in ~/.local/share
    local data_dir="$USER_HOME/.local/share/$PKG"
    if [[ -d "$data_dir" ]]; then
        log_info "Removing data dir: $data_dir"
        rm -rf "$data_dir"
        PURGED=1
    fi

    if [[ $PURGED -eq 1 ]]; then
        # Refresh the desktop database so the app menu updates immediately
        sudo -u "$SUDO_USER" update-desktop-database \
            "$USER_HOME/.local/share/applications" 2>/dev/null || true
        log_ok "XDG artifacts purged for $PKG."
    else
        log_info "No XDG artifacts found for $PKG."
    fi
}

#%%%%%%%%%%%%%%%%%%%%%% Search %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

search_pkg() {
    local PKG="$1"
    local FOUND=0

    log_info "Searching for ${BOLD}$PKG${NC}..."

    if pacman_has "$PKG"; then
        log_ok "Found in pacman (Arch)"
        FOUND=1
    fi

    if command_exists yay && aur_has "$PKG"; then
        log_ok "Found in AUR"
        FOUND=1
    fi

    echo -e "${CYAN}→${NC} Checking Debian container..."
    if apt_has "$PKG"; then
        log_ok "Found in Debian container"
        FOUND=1
    fi

    echo -e "${CYAN}→${NC} Checking Fedora container..."
    if dnf_has "$PKG"; then
        log_ok "Found in Fedora container"
        FOUND=1
    fi

    echo -e "${CYAN}→${NC} Checking Flatpak..."
    local flatpak_id
    flatpak_id="$(flatpak_resolve "$PKG" 2>/dev/null)" && {
        log_ok "Found in Flatpak ($flatpak_id)"
        FOUND=1
    }

    if [[ $FOUND -eq 0 ]]; then
        log_err "Package not found anywhere."
        exit 1
    fi
}

#%%%%%%%%%%%%%%%%%%%%%% Install %%%%%%%%%%%%%%%%%%%%%%%%%%%%

install_pkg() {
    local PKG="$1"
    local FORCED_SOURCE="$2"
    local DRY_RUN="$3"

    log_info "Installing ${BOLD}$PKG${NC}..."

    if [[ -n "$FORCED_SOURCE" ]]; then
        case "$FORCED_SOURCE" in
            pacman)
                pacman_has "$PKG" || { log_err "Not found in pacman"; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via pacman"; return 0; }
                acquire_lock "pacman"
                sudo pacman -S --needed "$PKG" && db_add "$PKG" "pacman"
                release_lock "pacman"
                ;;
            aur)
                aur_has "$PKG" || { log_err "Not found in AUR"; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via AUR"; return 0; }
                acquire_lock "aur"
                sudo -u "$SUDO_USER" yay -S "$PKG" && db_add "$PKG" "aur"
                release_lock "aur"
                ;;
            debian)
                echo -e "${CYAN}→${NC} Checking Debian container..."
                apt_has "$PKG" || { log_err "Not found in Debian container"; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via Debian container"; return 0; }
                acquire_lock "debian"
                sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- sudo apt install -y "$PKG" \
                    && distrobox_export "$PKG" "$DEBIAN_BOX" \
                    && db_add "$PKG" "debian"
                release_lock "debian"
                ;;
            fedora)
                echo -e "${CYAN}→${NC} Checking Fedora container..."
                dnf_has "$PKG" || { log_err "Not found in Fedora container"; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via Fedora container"; return 0; }
                acquire_lock "fedora"
                sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf install -y "$PKG" \
                    && distrobox_export "$PKG" "$FEDORA_BOX" \
                    && db_add "$PKG" "fedora"
                release_lock "fedora"
                ;;
            flatpak)
                echo -e "${CYAN}→${NC} Checking Flatpak..."
                local forced_app_id
                forced_app_id="$(flatpak_resolve "$PKG")" || { log_err "Not found in Flatpak"; return 1; }
                [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $forced_app_id via Flatpak"; return 0; }
                acquire_lock "flatpak"
                flatpak install -y "$forced_app_id" && db_add "$forced_app_id" "flatpak"
                release_lock "flatpak"
                ;;
            *)
                log_err "Invalid source: $FORCED_SOURCE"
                return 1
                ;;
        esac
        return 0
    fi

    # Default priority order
    if pacman_has "$PKG"; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via pacman"; return 0; }
        acquire_lock "pacman"
        sudo pacman -S --needed "$PKG" && db_add "$PKG" "pacman"
        release_lock "pacman"
        return 0
    fi

    if command_exists yay && aur_has "$PKG"; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via AUR"; return 0; }
        acquire_lock "aur"
        sudo -u "$SUDO_USER" yay -S "$PKG" && db_add "$PKG" "aur"
        release_lock "aur"
        return 0
    fi

    echo -e "${CYAN}→${NC} Checking Flatpak..."
    local app_id
    app_id="$(flatpak_resolve "$PKG" 2>/dev/null)" && {
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $app_id via Flatpak"; return 0; }
        acquire_lock "flatpak"
        flatpak install -y "$app_id" && db_add "$app_id" "flatpak"
        release_lock "flatpak"
        return 0
    }

    echo -e "${CYAN}→${NC} Checking Debian container..."
    if apt_has "$PKG"; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via Debian container"; return 0; }
        acquire_lock "debian"
        sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- sudo apt install -y "$PKG" \
            && distrobox_export "$PKG" "$DEBIAN_BOX" \
            && db_add "$PKG" "debian"
        release_lock "debian"
        return 0
    fi

    echo -e "${CYAN}→${NC} Checking Fedora container..."
    if dnf_has "$PKG"; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would install $PKG via Fedora container"; return 0; }
        acquire_lock "fedora"
        sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf install -y "$PKG" \
            && distrobox_export "$PKG" "$FEDORA_BOX" \
            && db_add "$PKG" "fedora"
        release_lock "fedora"
        return 0
    fi

    log_err "Package '$PKG' not found anywhere."
    return 1
}

#%%%%%%%%%%%%%%%%%%%%%% Remove %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

remove_pkg() {
    local PKG="$1"
    local DRY_RUN="$2"
    local PURGE="$3"
    local FOUND=0

    log_info "Searching for installed ${BOLD}$PKG${NC}..."

    if pacman -Qi "$PKG" &>/dev/null; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via pacman"; FOUND=1; }
        if [[ "$DRY_RUN" != "1" ]]; then
            log_info "Removing $PKG via pacman..."
            acquire_lock "pacman"
            sudo pacman -Rns "$PKG" && db_remove "$PKG"
            release_lock "pacman"
            FOUND=1
        fi
    fi

    if command_exists yay && yay -Qi "$PKG" &>/dev/null; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via AUR"; FOUND=1; }
        if [[ "$DRY_RUN" != "1" ]]; then
            log_info "Removing $PKG via AUR..."
            acquire_lock "aur"
            sudo -u "$SUDO_USER" yay -Rns "$PKG" && db_remove "$PKG"
            release_lock "aur"
            FOUND=1
        fi
    fi

    echo -e "${CYAN}→${NC} Checking Debian container..."
    if sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- dpkg -s "$PKG" &>/dev/null; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via Debian container"; FOUND=1; }
        if [[ "$DRY_RUN" != "1" ]]; then
            log_info "Removing $PKG via Debian container..."
            acquire_lock "debian"
            sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- sudo apt remove -y "$PKG" && db_remove "$PKG"
            release_lock "debian"
            [[ "$PURGE" == "1" ]] && purge_xdg_exports "$PKG"
            FOUND=1
        fi
    fi

    echo -e "${CYAN}→${NC} Checking Fedora container..."
    if sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- rpm -q "$PKG" &>/dev/null; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $PKG via Fedora container"; FOUND=1; }
        if [[ "$DRY_RUN" != "1" ]]; then
            log_info "Removing $PKG via Fedora container..."
            acquire_lock "fedora"
            sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf remove -y "$PKG" && db_remove "$PKG"
            release_lock "fedora"
            [[ "$PURGE" == "1" ]] && purge_xdg_exports "$PKG"
            FOUND=1
        fi
    fi

    echo -e "${CYAN}→${NC} Checking Flatpak..."
    # For Flatpak, PKG may be a friendly name or an app ID — check DB first
    local fp_id
    fp_id="$(db_source "$PKG")"
    if [[ "$fp_id" == "flatpak" ]]; then
        # DB stores the app ID as the package name for Flatpak installs
        fp_id="$PKG"
    else
        fp_id=""
    fi
    # Also check if it's currently installed as a Flatpak regardless of DB
    if [[ -z "$fp_id" ]] && flatpak info "$PKG" &>/dev/null; then
        fp_id="$PKG"
    fi

    if [[ -n "$fp_id" ]]; then
        [[ "$DRY_RUN" == "1" ]] && { echo -e "  ${YELLOW}[dry-run]${NC} Would remove $fp_id via Flatpak"; FOUND=1; }
        if [[ "$DRY_RUN" != "1" ]]; then
            log_info "Removing $fp_id via Flatpak..."
            acquire_lock "flatpak"
            flatpak uninstall -y "$fp_id" && db_remove "$PKG"
            release_lock "flatpak"
            FOUND=1
        fi
    fi

    if [[ $FOUND -eq 0 ]]; then
        log_warn "Package '$PKG' is not installed anywhere."
        return 1
    fi

    [[ "$DRY_RUN" != "1" ]] && log_ok "$PKG removed."
    return 0
}

#%%%%%%%%%%%%%%%%%%%%%% Update %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

update_all() {
    log_info "Updating Arch packages..."
    acquire_lock "pacman"
    sudo pacman -Syu || { log_err "pacman update failed. Aborting."; release_lock "pacman"; exit 1; }
    release_lock "pacman"

    if command_exists yay; then
        log_info "Updating AUR packages..."
        acquire_lock "aur"
        sudo -u "$SUDO_USER" yay -Syu || { log_err "yay update failed. Aborting."; release_lock "aur"; exit 1; }
        release_lock "aur"
    fi

    log_info "Updating Debian container..."
    acquire_lock "debian"
    sudo -u "$SUDO_USER" distrobox enter "$DEBIAN_BOX" -- bash -c "sudo apt update && sudo apt upgrade -y" \
        || { log_err "Debian update failed. Aborting."; release_lock "debian"; exit 1; }
    release_lock "debian"

    log_info "Updating Fedora container..."
    acquire_lock "fedora"
    sudo -u "$SUDO_USER" distrobox enter "$FEDORA_BOX" -- sudo dnf upgrade -y \
        || { log_err "Fedora update failed. Aborting."; release_lock "fedora"; exit 1; }
    release_lock "fedora"

    if command_exists flatpak; then
        log_info "Updating Flatpak packages..."
        acquire_lock "flatpak"
        flatpak update -y \
            || { log_err "Flatpak update failed. Aborting."; release_lock "flatpak"; exit 1; }
        release_lock "flatpak"
    fi

    log_ok "Update complete."
}

#%%%%%%%%%%%%%%%%%%%%%% List %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

list_pkgs() {
    local FILTER_SOURCE="$1"

    if [[ ! -f "$DB_FILE" ]] || [[ $(wc -l < "$DB_FILE") -le 1 ]]; then
        echo -e "${YELLOW}No packages tracked yet.${NC}"
        return 0
    fi

    echo -e "\n${BOLD}Magnet-managed packages:${NC}\n"
    printf "  ${BOLD}%-30s %-10s %-20s %s${NC}\n" "Package" "Source" "Date" "User"
    echo "  $(printf '%.0s─' {1..70})"

    while IFS=',' read -r pkg source date user; do
        [[ "$pkg" == "package" ]] && continue  # skip header
        [[ -n "$FILTER_SOURCE" && "$source" != "$FILTER_SOURCE" ]] && continue
        printf "  %-30s %-10s %-20s %s\n" "$pkg" "$source" "$date" "$user"
    done < "$DB_FILE"

    echo ""
}

#%%%%%%%%%%%%%%%%%%%%%% Info %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

info_pkg() {
    local PKG="$1"
    local row
    row="$(db_get "$PKG")"

    if [[ -z "$row" ]]; then
        log_warn "$PKG is not tracked by Magnet."
        return 1
    fi

    local source date user
    source="$(echo "$row" | cut -d',' -f2)"
    date="$(echo "$row" | cut -d',' -f3)"
    user="$(echo "$row" | cut -d',' -f4)"

    echo -e "\n${BOLD}$PKG${NC}"
    echo -e "  ${CYAN}Source:${NC}   $source"
    echo -e "  ${CYAN}Installed:${NC} $date"
    echo -e "  ${CYAN}By:${NC}       $user\n"
}

#%%%%%%%%%%%%%%%%%%%%%% Why %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

why_pkg() {
    local PKG="$1"
    local row
    row="$(db_get "$PKG")"

    if [[ -z "$row" ]]; then
        log_warn "$PKG is not tracked by Magnet. It may have been installed outside of Magnet."
        return 1
    fi

    local user date source
    user="$(echo "$row" | cut -d',' -f4)"
    date="$(echo "$row" | cut -d',' -f3)"
    source="$(echo "$row" | cut -d',' -f2)"

    echo -e "\n  ${BOLD}$PKG${NC} was installed by ${GREEN}$user${NC} on ${CYAN}$date${NC} from ${YELLOW}$source${NC}.\n"
}

#%%%%%%%%%%%%%%%%%%%%%% Export %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

export_pkgs() {
    local PROFILE="$1"
    local DEST="$PROFILES_DIR/$PROFILE.csv"

    if [[ ! -f "$DB_FILE" ]] || [[ $(wc -l < "$DB_FILE") -le 1 ]]; then
        log_warn "No packages to export."
        return 1
    fi

    cp "$DB_FILE" "$DEST"
    log_ok "Exported to $DEST"
}

#%%%%%%%%%%%%%%%%%%%%%% Import %%%%%%%%%%%%%%%%%%%%%%%%%%%%%

import_pkgs() {
    local PROFILE="$1"
    local SRC="$PROFILES_DIR/$PROFILE.csv"

    if [[ ! -f "$SRC" ]]; then
        log_err "Profile '$PROFILE' not found at $SRC"
        return 1
    fi

    log_info "Importing profile ${BOLD}$PROFILE${NC}..."

    local FAILED=()
    while IFS=',' read -r pkg source date user; do
        [[ "$pkg" == "package" ]] && continue  # skip header
        log_info "Installing $pkg from $source..."
        if ! install_pkg "$pkg" "$source" "0"; then
            FAILED+=("$pkg")
        fi
    done < "$SRC"

    if [[ ${#FAILED[@]} -gt 0 ]]; then
        log_err "Failed to install: ${FAILED[*]}"
        return 1
    fi

    log_ok "Profile '$PROFILE' imported successfully."
}

#%%%%%%%%%%%%%%%%%%%%%% Log %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

show_log() {
    if [[ ! -f "$LOGFILE" ]]; then
        log_warn "No log file found at $LOGFILE"
        return 0
    fi

    echo -e "\n${BOLD}Magnet Log${NC}\n"

    while IFS= read -r line; do
        if [[ "$line" == *"✔"* ]] || [[ "$line" == *"complete"* ]] || [[ "$line" == *"Finished"* ]]; then
            echo -e "  ${GREEN}$line${NC}"
        elif [[ "$line" == *"✘"* ]] || [[ "$line" == *"failed"* ]] || [[ "$line" == *"Error"* ]]; then
            echo -e "  ${RED}$line${NC}"
        elif [[ "$line" == *"⚠"* ]] || [[ "$line" == *"warn"* ]]; then
            echo -e "  ${YELLOW}$line${NC}"
        else
            echo -e "  ${CYAN}$line${NC}"
        fi
    done < "$LOGFILE"

    echo ""
}

#%%%%%%%%%%%%%%%%%%%%%%%%%% CLI %%%%%%%%%%%%%%%%%%%%%%%%%%%%

case "$1" in

    install)
        shift

        SOURCE=""
        DRY_RUN="0"
        PACKAGES=()

        for arg in "$@"; do
            if [[ "$arg" == --source=* ]]; then
                SOURCE="${arg#--source=}"
            elif [[ "$arg" == "--dry-run" ]]; then
                DRY_RUN="1"
            else
                PACKAGES+=("$arg")
            fi
        done

        if [[ ${#PACKAGES[@]} -eq 0 ]]; then
            echo -e "${RED}Error:${NC} No packages specified."
            exit 1
        fi

        [[ "$DRY_RUN" == "1" ]] && echo -e "\n${YELLOW}Dry run — no changes will be made.${NC}\n"

        FAILED=()
        for pkg in "${PACKAGES[@]}"; do
            if ! install_pkg "$pkg" "$SOURCE" "$DRY_RUN"; then
                FAILED+=("$pkg")
            fi
        done

        if [[ ${#FAILED[@]} -gt 0 ]]; then
            echo ""
            log_err "Failed to install: ${FAILED[*]}"
            exit 1
        fi
        ;;

    remove)
        shift

        DRY_RUN="0"
        PURGE="1"
        PACKAGES=()

        for arg in "$@"; do
            if [[ "$arg" == "--dry-run" ]]; then
                DRY_RUN="1"
            elif [[ "$arg" == "--no-purge" ]]; then
                PURGE="0"
            else
                PACKAGES+=("$arg")
            fi
        done

        if [[ ${#PACKAGES[@]} -eq 0 ]]; then
            echo -e "${RED}Error:${NC} No packages specified."
            exit 1
        fi

        [[ "$DRY_RUN" == "1" ]] && echo -e "\n${YELLOW}Dry run — no changes will be made.${NC}\n"
        [[ "$PURGE" == "0" ]] && echo -e "\n${YELLOW}Note: XDG export artifacts will not be purged.${NC}\n"

        FAILED=()
        for pkg in "${PACKAGES[@]}"; do
            if ! remove_pkg "$pkg" "$DRY_RUN" "$PURGE"; then
                FAILED+=("$pkg")
            fi
        done

        if [[ ${#FAILED[@]} -gt 0 ]]; then
            echo ""
            log_err "Not found / failed to remove: ${FAILED[*]}"
            exit 1
        fi
        ;;

    search)
        search_pkg "$2"
        ;;

    update)
        update_all
        ;;

    list)
        FILTER=""
        if [[ "${2:-}" == --source=* ]]; then
            FILTER="${2#--source=}"
        fi
        list_pkgs "$FILTER"
        ;;

    info)
        info_pkg "$2"
        ;;

    why)
        why_pkg "$2"
        ;;

    export)
        export_pkgs "$2"
        ;;

    import)
        import_pkgs "$2"
        ;;

    log)
        show_log
        ;;

    *)
        echo -e "
${BOLD}Magnet${NC} — Package Management Wrapper v0.5

${BOLD}Usage:${NC}
  magnet install [--source=pacman|aur|debian|fedora|flatpak] [--dry-run] <pkg> [pkg2 ...]
  magnet remove  [--dry-run] [--no-purge] <pkg> [pkg2 ...]
  magnet search  <pkg>
  magnet update
  magnet list    [--source=pacman|aur|debian|fedora|flatpak]
  magnet info    <pkg>
  magnet why     <pkg>
  magnet export  <profile>
  magnet import  <profile>
  magnet log

${BOLD}Notes:${NC}
  --no-purge    Skip XDG desktop entry/icon cleanup on remove (container packages only)
  --dry-run     Preview what would happen without making any changes
  --source      Force a specific package manager (install priority otherwise:
                pacman → AUR → Flatpak → Debian → Fedora)
"
        ;;
esac
